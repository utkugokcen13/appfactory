# App Factory — Streamlit Cloud secrets template
#
# DO NOT commit a real `secrets.toml` to git. This `.example` file is a
# safe-to-commit template documenting which keys are required.
#
# How to use:
#   1. Open https://share.streamlit.io → your app → Settings → Secrets
#   2. Paste the contents below into the editor
#   3. Replace every `<...>` placeholder with a real value
#   4. Save — Streamlit auto-restarts with the new secrets

# ── AWS Bedrock (read from your local .env) ──────────────────────────────
AWS_BEARER_TOKEN_BEDROCK = "<paste-from-your-.env>"
AWS_REGION = "us-west-2"

# ── Turso libSQL (free tier — gives us persistent DB on ephemeral host) ──
# Get these from https://turso.tech dashboard:
#   URL: shown at the top of your database page
#   Token: "Generate Token" → expiration "Never" (copy on first display!)
LIBSQL_URL = "<libsql://appfactory-...turso.io>"
LIBSQL_AUTH_TOKEN = "<eyJhbGciOi...long-jwt-token>"

# ── Auth cookie signing key (rotate this to invalidate all sessions) ─────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
AUTH_COOKIE_KEY = "<32+ char random string>"

# ── Per-user cap overrides (optional — defaults are generous) ────────────
# CAP_DAILY_RUNS = "20"
# CAP_DAILY_TOKENS = "1000000"
# CAP_CONCURRENT_PER_USER = "1"
